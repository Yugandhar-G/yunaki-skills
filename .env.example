# GEMINI_API_KEY is only a FALLBACK now. By default yunaki drives whatever
# coding-agent CLI is installed on the host (claude/codex/cursor-agent/gemini/
# aider) and reuses that CLI's own auth — run `yunaki doctor` to see what was
# detected. A key is only needed if no CLI is found, or if you pin meta-ops to a
# Gemini model via YUNAKI_SKILL_MODEL.
GEMINI_API_KEY=your-gemini-api-key
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/yunaki?appName=Cluster0
MONGO_DB=yunaki
DO_MODEL_ACCESS_KEY=your-do-key

# ─── Coding-agent backend (execution pivot) ──────────────────────────────────
# Force a specific backend instead of auto-detecting. One of:
#   claude | codex | cursor | gemini-cli | aider | gemini-sdk
# Unset = auto-detect the first installed CLI, falling back to the Gemini SDK.
# YUNAKI_AGENT_BACKEND=claude
#
# Pin the skill model's meta-ops (extract/evolve/judge) to a Gemini model.
# Unset = route meta-ops through the detected host CLI (no key needed).
# YUNAKI_SKILL_MODEL=gemini-2.5-flash

# ─── God-level loop knobs (all default to today's behavior) ───────────────────
# Contrastive extraction: rollouts per failure (1 = off, single-trace extract).
# YUNAKI_CONTRASTIVE_ROLLOUTS=1
#
# Composite reward: layer LLM-judge align+quality on top of pytest (signal only,
# never flips the pytest pass/fail gate). Off by default.
# YUNAKI_COMPOSITE_REWARD=false
# YUNAKI_REWARD_W_EXEC=0.75
# YUNAKI_REWARD_W_QUALITY=0.25
#
# Score-weighted retrieval. Off by default (quality weights 0.0 = pure cosine).
# Raise the score/rate weights to let proven, higher-scoring skills win ties.
# YUNAKI_RANK_W_SIM=1.0
# YUNAKI_RANK_W_SCORE=0.0
# YUNAKI_RANK_W_RATE=0.0
#
# Skill consolidation (yunaki skills consolidate): dedup/drop thresholds.
# YUNAKI_CONSOLIDATE_SIM=0.92
# YUNAKI_CONSOLIDATE_MIN_USAGE=5
# YUNAKI_CONSOLIDATE_MAX_FAIL_RATE=0.34
# YUNAKI_CONSOLIDATE_SCORE_FLOOR=0

# Redis (skill-embedding cache). Defaults to localhost; docker-compose overrides
# this to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0

# API-key auth. Off by default for local dev so the dashboard works without a
# key; the docker-compose stack sets this to true.
AUTH_ENABLED=false

# Skill governance: when true (default) loop-evolved skills are auto-approved
# (ACTIVE) so the live evolution loop keeps improving. Set false to require
# manual approval of evolved skills via /api/skills/{id}/approve.
SKILL_AUTO_APPROVE=true
