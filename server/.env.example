# Copy to repo-root .env and fill in. NEVER commit the real .env (it's gitignored).

# Per-repo access tokens: JSON of {token: "owner/repo"}. Each token only ever reads or
# writes that one repo's slice of the store. Generate strong random tokens, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
YUNAKI_TOKENS={"REPLACE_WITH_RANDOM_TOKEN":"owner/repo"}

# GitHub webhook secret — set the SAME value in each repo's webhook settings
# (Settings -> Webhooks -> Secret). Verifies POST /webhook really came from GitHub.
YUNAKI_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# GitHub token the PR ingester uses (read access to the repos you ingest). A fine-grained
# PAT or a GitHub App installation token with Contents+PullRequests: read.
GH_TOKEN=ghp_REPLACE_ME
